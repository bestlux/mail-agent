{
  "name": "@iomancer/mail-agent-daemon",
  "version": "0.1.0",
  "description": "Local MCP daemon for Mail Agent mailbox, calendar, and contacts workflows.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bestlux/mail-agent.git"
  },
  "homepage": "https://github.com/bestlux/mail-agent",
  "bugs": {
    "url": "https://github.com/bestlux/mail-agent/issues"
  },
  "dependencies": {
    "@iomancer/mail-agent-shared": "workspace:*",
    "@modelcontextprotocol/sdk": "1.28.0",
    "fast-xml-parser": "5.5.9",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "typescript": "6.0.2",
    "vitest": "4.1.2"
  },
  "keywords": [
    "codex",
    "mcp",
    "fastmail",
    "mail",
    "calendar",
    "contacts"
  ]
}
