{
  "name": "mail-agent",
  "version": "0.1.0",
  "description": "Provider-native Codex plugin bundle for agent workflows across mail, calendar, and contacts.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "mail-agent": "./dist/bin/mail-agent.js"
  },
  "files": [
    "dist",
    ".codex-plugin",
    ".mcp.json",
    "skills",
    "assets",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@iomancer/mail-agent-daemon": "workspace:*",
    "@iomancer/mail-agent-shared": "workspace:*",
    "commander": "14.0.3"
  },
  "devDependencies": {
    "@types/node": "25.5.2",
    "typescript": "6.0.2",
    "vitest": "4.1.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bestlux/mail-agent.git"
  },
  "homepage": "https://github.com/bestlux/mail-agent",
  "bugs": {
    "url": "https://github.com/bestlux/mail-agent/issues"
  },
  "keywords": [
    "codex",
    "plugin",
    "mcp",
    "fastmail",
    "gmail",
    "google",
    "email",
    "calendar",
    "contacts"
  ]
}
